<!DOCTYPE html>
<html lang="en">
    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>

</head>
<body>
    <div class="w-full h-screen bg-zinc-900 text-white p-10">
        <h3 class="text-3xl mb-3">Login your account</h3>
        <form method="get" action="/login">
            <input class="px-3 py-2 rounded-md border-2 border-zinc-800 bg-transparent outline-none" type="email" placeholder="email" name="email">
            <input class="px-3 py-2 rounded-md border-2 border-zinc-800 bg-transparent outline-none" type="password" placeholder="password" name="password">
            <input type="submit" class="px-4 py-2 rounded-md bg-blue-500" value="Login User">
        </form>
    </div>
</body>
</html>